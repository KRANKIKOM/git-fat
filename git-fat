#!/usr/bin/env bash
# Run git-fat via Docker. Git filter hooks invoke this script from the host PATH.
set -euo pipefail

IMAGE="${GIT_FAT_IMAGE:-git-fat:latest}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v docker >/dev/null 2>&1; then
    echo "git-fat requires Docker. Install Docker or set git-fat in PATH from a container." >&2
    exit 1
fi

if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
    echo "Building ${IMAGE}..." >&2
    docker build -t "${IMAGE}" "${SCRIPT_DIR}"
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cwd="$(pwd)"

docker_args=(
    run --rm
    -v "${repo_root}:${repo_root}"
    -w "${cwd}"
    -e GIT_FAT_VERBOSE="${GIT_FAT_VERBOSE:-}"
    -e GIT_FAT_VERSION="${GIT_FAT_VERSION:-}"
)

if [[ -d "${HOME}/.ssh" ]]; then
    docker_args+=(-v "${HOME}/.ssh:/root/.ssh:ro")
fi

docker_args+=("${IMAGE}" "$@")
exec docker "${docker_args[@]}"
